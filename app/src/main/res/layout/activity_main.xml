<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Market Price Search"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/cropInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Crop (e.g., Wheat/गेहूं)" />

                <EditText
                    android:id="@+id/districtInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="District (e.g., Pune)" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/searchBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Search" />

                    <Button
                        android:id="@+id/retryBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Retry" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watchlist"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/watchCropInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Crop" />

                <EditText
                    android:id="@+id/watchDistrictInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="District" />

                <Button
                    android:id="@+id/addWatchBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add to watchlist" />

                <TextView
                    android:id="@+id/watchlistText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No items in watchlist" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Land Unit Converter"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/unitValueInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Value"
                    android:inputType="numberDecimal" />

                <Spinner
                    android:id="@+id/fromUnit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <Spinner
                    android:id="@+id/toUnit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/convertBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Convert" />

                <TextView
                    android:id="@+id/convertResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
